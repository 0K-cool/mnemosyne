#!/usr/bin/env bash
# AUTO-GENERATED by Mnemosyne v{{GENERATOR_VERSION}} вҖ” do not edit by hand.
# Source memory entry: {{GENERATED_FROM}}
# Generated at: {{GENERATED_AT}}
# Regenerate: mnemosyne enforce --rule {{GENERATED_FROM}}
#
# Behavior:
#   PreToolUse hook on tool {{TOOL}} matching pattern {{PATTERN_JSON}}.
#   Generic block-on-match primitive вҖ” pattern matches вҶ’ block.
#   Audit trail: {{AUDIT_LOG_PATH}}.
#
#   Shell port вҖ” same semantics as block-on-match-guard.ts.template
#   without the bun runtime dep. REQUIRES jq for JSON parsing; that's
#   the price of getting away from a JS runtime entirely. Action-time
#   re-injection (Phase 2) is TS-only; this port deliberately ignores
#   `inject_on_match`.

set -euo pipefail

# Hook path is .claude/hooks/auto/<file>.sh вҖ” three `..` to reach repo root.
HOOK_FILE="${BASH_SOURCE[0]}"
PAI_DIR="${PAI_DIR:-$(cd "$(dirname "$HOOK_FILE")/../../.." && pwd)}"
AUDIT_PATH="$PAI_DIR/{{AUDIT_LOG_PATH}}"
PATTERN={{PATTERN_SH}}

# jq is required for safe JSON extraction. Failing without it would
# either silently mis-parse or fall through to no-op.
if ! command -v jq >/dev/null 2>&1; then
  echo "[block-on-match-guard] jq is required for the shell port вҖ” install jq and regenerate, or use language: ts / py" >&2
  exit 0
fi

append_audit() {
  # Args: $1 = JSON object literal (already escaped). Caller is
  # responsible for not passing untrusted strings unquoted.
  local entry="$1"
  local ts
  ts=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
  mkdir -p "$(dirname "$AUDIT_PATH")" 2>/dev/null || true
  # Merge timestamp into the entry via jq so we never hand-roll JSON
  # in shell вҖ” that's the lane where escapes go wrong silently.
  if echo "$entry" | jq -c --arg ts "$ts" '. + {ts: $ts}' >> "$AUDIT_PATH" 2>/dev/null; then
    return 0
  fi
  echo "[block-on-match-guard] audit write to $AUDIT_PATH failed" >&2
}

emit_block() {
  local reason="$1"
  # 60 inner chars between в”Ӯ rails. Pad each line to that width.
  local W=60
  pad() {
    local s="$1"
    local len=${#s}
    if [ "$len" -ge "$W" ]; then
      printf '%s' "${s:0:$W}"
    else
      printf '%s%*s' "$s" "$((W - len))" ""
    fi
  }
  {
    echo
    echo 'в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ'
    printf 'в”Ӯ%sв”Ӯ\n' "$(pad '  рҹӣ‘ BLOCK-ON-MATCH GUARD вҖ” BLOCKED')"
    echo 'в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө'
    printf 'в”Ӯ%sв”Ӯ\n' "$(pad "  Reason: $reason")"
    printf 'в”Ӯ%sв”Ӯ\n' "$(pad "  Pattern: $PATTERN")"
    printf 'в”Ӯ%sв”Ӯ\n' "$(pad '')"
    printf 'в”Ӯ%sв”Ӯ\n' "$(pad '  Source rule: {{GENERATED_FROM}}')"
    printf 'в”Ӯ%sв”Ӯ\n' "$(pad '')"
    printf 'в”Ӯ%sв”Ӯ\n' "$(pad '  This hook always blocks on match. Edit the source')"
    printf 'в”Ӯ%sв”Ӯ\n' "$(pad '  memory entry to refine the pattern.')"
    echo 'в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ'
    echo
  } >&2
  append_audit "$(jq -n --arg reason "$reason" --arg pattern "$PATTERN" \
    '{event: "block", reason: $reason, pattern: $pattern}')"
  exit 2
}

main() {
  local input tool cmd
  if ! input=$(cat); then
    # Match the TS / py templates' fail-open posture for non-credential
    # guards: hook can't read input вҶ’ audit-only allow.
    exit 0
  fi
  if ! tool=$(echo "$input" | jq -r '.tool_name // empty' 2>/dev/null); then
    exit 0
  fi
  if [ "$tool" != "{{TOOL}}" ]; then
    exit 0
  fi
  cmd=$(echo "$input" | jq -r '.tool_input.command // empty' 2>/dev/null) || cmd=""
  if ! echo "$cmd" | grep -qE -- "$PATTERN"; then
    exit 0
  fi

  emit_block "pattern matched"
}

main
