#!/usr/bin/env python3
# AUTO-GENERATED by Mnemosyne v{{GENERATOR_VERSION}} — do not edit by hand.
# Source memory entry: {{GENERATED_FROM}}
# Generated at: {{GENERATED_AT}}
# Regenerate: mnemosyne enforce --rule {{GENERATED_FROM}}
#
# Behavior:
#   PreToolUse hook on tool {{TOOL}} matching pattern {{PATTERN_JSON}}.
#   Generic block-on-match primitive — pattern matches → block.
#   No cache, no diff check, no allow path. Use this template for
#   "always block this command" rules. Audit trail: {{AUDIT_LOG_PATH}}.
#
#   Python port — same semantics as block-on-match-guard.ts.template,
#   but no `bun` runtime dep. Stdlib only (json, os, re, sys, pathlib,
#   datetime). Action-time re-injection (Phase 2) is currently TS-only;
#   this port deliberately ignores `inject_on_match`.

from __future__ import annotations

import json
import os
import re
import sys
from datetime import datetime, timezone
from pathlib import Path

# Hook path is .claude/hooks/auto/<file>.py — three `..` to reach repo root.
_PAI_DIR = Path(os.environ.get("PAI_DIR") or Path(__file__).resolve().parents[3])
AUDIT_PATH = _PAI_DIR / "{{AUDIT_LOG_PATH}}"
PATTERN = re.compile({{PATTERN_JSON}})


def append_audit(entry: dict) -> None:
    try:
        AUDIT_PATH.parent.mkdir(parents=True, exist_ok=True)
        line = json.dumps(
            {"ts": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"), **entry}
        )
        with AUDIT_PATH.open("a", encoding="utf-8") as f:
            f.write(line + "\n")
    except OSError as err:
        print(
            f"[block-on-match-guard] audit write to {AUDIT_PATH} failed: {err}",
            file=sys.stderr,
        )


def emit_block(reason: str) -> "None":
    # Box width = 60 inner chars between the │ rails (61 dashes for the borders).
    width = 60

    def pad(s: str) -> str:
        return s[:width] if len(s) >= width else s + " " * (width - len(s))

    lines = [
        "",
        "┌──────────────────────────────────────────────────────────────┐",
        f"│{pad('  🛑 BLOCK-ON-MATCH GUARD — BLOCKED')}│",
        "├──────────────────────────────────────────────────────────────┤",
        f"│{pad('  Reason: ' + reason)}│",
        f"│{pad('  Pattern: ' + PATTERN.pattern)}│",
        f"│{pad('')}│",
        f"│{pad('  Source rule: {{GENERATED_FROM}}')}│",
        f"│{pad('')}│",
        f"│{pad('  This hook always blocks on match. Edit the source')}│",
        f"│{pad('  memory entry to refine the pattern.')}│",
        "└──────────────────────────────────────────────────────────────┘",
        "",
    ]
    print("\n".join(lines), file=sys.stderr)
    append_audit({"event": "block", "reason": reason, "pattern": PATTERN.pattern})
    sys.exit(2)


def main() -> None:
    try:
        data = json.loads(sys.stdin.read())
    except (ValueError, OSError):
        # Match the TS template's fail-open posture for non-credential
        # guards: a hook that can't read its input shouldn't block all
        # tool calls. Audit-only.
        sys.exit(0)

    if data.get("tool_name") != "{{TOOL}}":
        sys.exit(0)
    cmd = (data.get("tool_input") or {}).get("command") or ""
    if not PATTERN.search(cmd):
        sys.exit(0)

    emit_block("pattern matched")


if __name__ == "__main__":
    main()
